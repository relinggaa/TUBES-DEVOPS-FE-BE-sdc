# ── Git / VCS ─────────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes
.github

# ── Local development ─────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules
npm-debug.log*

# ── PHP dev ───────────────────────────────────────────────────────────────────
vendor
.phpunit.cache
.phpunit.result.cache
phpunit.xml
# Bootstrap cache — regenerated by entrypoint (may contain dev-only references)
bootstrap/cache/*.php

# ── Storage (mounted as volume in production) ─────────────────────────────────
storage/app/public
storage/logs
storage/framework/cache
storage/framework/sessions
storage/framework/views

# ── Frontend build artifacts (built inside Docker) ────────────────────────────
public/build
public/hot
public/storage

# ── Tests ─────────────────────────────────────────────────────────────────────
tests
coverage
test_cases.*

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode
.idea
.nova
.zed
.fleet
.editorconfig
*.code-workspace

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Docker compose/ignore files (Dockerfile itself and compose files not needed inside image)
# NOTE: docker/ directory must stay in build context — Dockerfile COPYs those configs
docker-compose*.yml
.dockerignore

# ── Misc ─────────────────────────────────────────────────────────────────────
README.md
stride.md
sonar-project.properties
vitest.config.js
